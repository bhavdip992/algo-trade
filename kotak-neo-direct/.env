# ════════════════════════════════════════════════════════════════════════
#  .env — Kotak Neo Auto-Trader  GREEDY v5.0
#  NEVER commit to git. Add .env to .gitignore.
# ════════════════════════════════════════════════════════════════════════

# ── Kotak Neo Credentials ────────────────────────────────────────────────
KOTAK_CONSUMER_KEY=1a1ec856-1528-46ef-95fa-6e2a70c489a6
KOTAK_MOBILE=+917048525286
KOTAK_UCC=XHHPN
KOTAK_MPIN=525286
KOTAK_TOTP_SECRET=NGSOHK4XSZXAKXS4EC42RWUZXA
ENVIRONMENT=prod

# ════════════════════════════════════════════════════════════════════════
#  TRADE MODE
#  true  = Paper trade (simulate, no real orders)
#  false = LIVE trade  (real money — double check before setting)
# ════════════════════════════════════════════════════════════════════════
PAPER_TRADE=false

# ════════════════════════════════════════════════════════════════════════
#  INDEX
#   NIFTY      → LOT_SIZE=65  STRIKE_STEP=50   EXPIRY_WEEKDAY=TUE
#   BANKNIFTY  → LOT_SIZE=30  STRIKE_STEP=100  EXPIRY_WEEKDAY=WED
#   FINNIFTY   → LOT_SIZE=65  STRIKE_STEP=50   EXPIRY_WEEKDAY=THU
#   MIDCPNIFTY → LOT_SIZE=120 STRIKE_STEP=25   EXPIRY_WEEKDAY=THU
# ════════════════════════════════════════════════════════════════════════
INDEX=NIFTY
LOT_SIZE=65
STRIKE_STEP=50
EXPIRY_WEEKDAY=TUE

# ── Option settings ──────────────────────────────────────────────────────
EXPIRY_TYPE=Weekly          # Weekly | Monthly
STRIKE_MODE=OTM2             # ATM | OTM1 | OTM2 | ITM1
OPTION_TYPE=AUTO            # AUTO | CE Only | PE Only

# ── Candle timeframe ─────────────────────────────────────────────────────
TIMEFRAME=5                 # 1 | 3 | 5 | 10 | 15 (minutes)

# ════════════════════════════════════════════════════════════════════════
#  CAPITAL & RISK  — tuned for ₹20,000
# ════════════════════════════════════════════════════════════════════════
MAX_CAPITAL=100000           # Total capital
MAX_DAILY_LOSS=3            # Halt when loss > 3% = ₹1500
MAX_TRADES=3                # Max trades per day
MAX_PREMIUM=450             # Max option premium/share to buy
RISK_PCT=2.0                # Risk per trade = 2% of ₹50k = ₹1000
MAX_LOTS=1                  # Hard cap — keeps cost under ₹15k/trade

# ════════════════════════════════════════════════════════════════════════
#  SIGNAL ENGINE  — GREEDY TUNED
# ════════════════════════════════════════════════════════════════════════

# EMA lengths
EMA_FAST=9
EMA_MID=21
EMA_SLOW=50
EMA_TREND=200               # needs 200 bars to warm up (~16 hrs of 5-min candles)

# Supertrend
ST_ATR_LEN=10
ST_FACTOR=3.0

# RSI  — tighter zones to avoid exhaustion entries
RSI_LEN=14
RSI_OB=68                   # CE blocked when RSI > 68 (overbought)
RSI_OS=32                   # PE blocked when RSI < 32 (oversold)

# ADX — trend strength gate
ADX_THRESH=20               # 18=balanced  25=strict

# Volume — IMPORTANT: set false for index spot feed (volume unreliable)
VOL_MULT=1.2
VOL_REQUIRED=false          # FALSE is correct for BANKNIFTY/NIFTY spot WebSocket

# Bollinger Bands
BB_LEN=20
BB_STD=2.0

# Minimum confirmations (out of 8 checks)
# 4=loose  5=balanced  6=strict
MIN_CONFIRMATIONS=5

# Stop Loss
SL_MODE=ATR                 # ATR | Fixed% | Swing
SL_ATR_MULT=1.2             # tighter SL → better RR
SL_PCT=0.5

# Target  — GREEDY: ATR-based scaling
TGT_MODE=ATR                # ATR gives score-scaled RR (2x to 3x)
TGT_PCT=1.5
TGT_ATR_MULT=2.5            # base; boosted to 3.5 on score≥8 signals

# Trailing Stop Loss  — GREEDY: tighter trail after partial exit
USE_TRAIL=true
TRAIL_TRIG=1.2              # activate trail after 1×ATR profit
TRAIL_STEP=0.6              # trail SL at 0.6×ATR below peak
