# ════════════════════════════════════════════════════════════════════
# .env — Kotak Neo Auto-Trader | Rs.20,000 | Greedy Trail Mode
# ════════════════════════════════════════════════════════════════════
# HOW GREEDY TRAIL WORKS (no fixed target):
#
#  Entry @ 48500  SL @ 48320  ATR = 150
#
#  Phase 1 — BREAKEVEN  (profit > 0.8×ATR = 120 pts)
#    Price hits 48620 → SL moves to 48500 (entry) → zero loss possible
#
#  Phase 2 — NORMAL TRAIL  (profit 120→300 pts)
#    Price at 48700 → SL = 48700 - 1.0×150 = 48550
#    Price at 48800 → SL = 48800 - 1.0×150 = 48650  (keeps moving up)
#
#  Phase 3 — GREEDY TIGHT TRAIL  (profit > 2.0×ATR = 300 pts)
#    Price at 48900 → SL = 48900 - 0.5×150 = 48825  (tight!)
#    Price at 49000 → SL = 49000 - 0.5×150 = 48925  (even tighter)
#    Trade stays open UNTIL trail SL is hit — no fixed target exit
# ════════════════════════════════════════════════════════════════════

# ── Kotak Neo Credentials ─────────────────────────────────────────
KOTAK_CONSUMER_KEY=1a1ec856-1528-46ef-95fa-6e2a70c489a6
KOTAK_MOBILE=+917048525286
KOTAK_UCC=XHHPN
KOTAK_MPIN=525286
KOTAK_TOTP_SECRET=NGSOHK4XSZXAKXS4EC42RWUZXA

# ── Environment ───────────────────────────────────────────────────
ENVIRONMENT=prod
PAPER_TRADE=true

# ── Server ────────────────────────────────────────────────────────
WEBHOOK_SECRET=1a1ec856-1528-46ef-95fa-6e2a70c489a6
PORT=5000
BRIDGE_URL=http://localhost:5000

# ── Index & Timeframe ─────────────────────────────────────────────
# NSE Jan 2026 lots: NIFTY=65 | BANKNIFTY=30 | FINNIFTY=60 | MIDCPNIFTY=120
# Expiry: BANKNIFTY=Wed | NIFTY=Thu | FINNIFTY=Tue | MIDCPNIFTY=Mon
INDEX=NIFTY
TIMEFRAME=5

# ── Capital ───────────────────────────────────────────────────────
MAX_CAPITAL=20000

# ── Daily Risk Limits ─────────────────────────────────────────────
# Daily loss limit = MAX_DAILY_LOSS% of MAX_CAPITAL
# Rs.20000 × 5% = Rs.1000 max loss per day → trading halts after this
MAX_DAILY_LOSS=5

# Max number of new trades per day (3 is safe for Rs.20k)
MAX_TRADES=3

# ── Per-Trade Risk ────────────────────────────────────────────────
# Risk per trade = RISK_PCT% of capital
# Rs.20000 × 2% = Rs.400 risk per trade
RISK_PCT=2.0

# ── Signal Scoring ────────────────────────────────────────────────
# Minimum score out of 10 algorithms to fire a signal
# 5 = balanced (2-4 signals/day)
# 6 = strict   (1-2 signals/day, higher quality)
# 4 = relaxed  (4-6 signals/day, more noise)
SIGNAL_SCORE=5

# ── Initial Stop Loss ─────────────────────────────────────────────
# SL placed at SL_ATR_MULT × ATR below entry
# ATR ~150 pts for BANKNIFTY → SL ~180 pts away
SL_ATR_MULT=1.2

# ── Greedy Trail — Phase 1: Breakeven ────────────────────────────
# Move SL to entry price (zero loss) after this much profit
# BREAKEVEN_ATR=0.8 → profit = 0.8×150 = 120 pts → SL to entry
BREAKEVEN_ATR=0.8

# ── Greedy Trail — Phase 2: Normal Trail ─────────────────────────
# SL follows price at TRAIL_ATR_MULT × ATR distance
# TRAIL_ATR_MULT=1.0 → SL always 1×150 = 150 pts below current price
TRAIL_ATR_MULT=1.0

# ── Greedy Trail — Phase 3: Tight Trail (near target zone) ───────
# When profit > GREEDY_ATR × ATR, tighten trail to GREEDY_TRAIL_MULT × ATR
# GREEDY_ATR=2.0      → activates when profit > 2×150 = 300 pts
# GREEDY_TRAIL_MULT=0.5 → tight trail = 0.5×150 = 75 pts from price
# This squeezes max profit while keeping the trade alive
GREEDY_ATR=1.0
GREEDY_TRAIL_MULT=0.5

# ── Target Mode ───────────────────────────────────────────────────
# USE_HARD_TARGET=false → GREEDY mode: no fixed exit, trail until SL hit
# USE_HARD_TARGET=true  → FIXED mode:  exit at TGT_RR × risk (old behaviour)
USE_HARD_TARGET=false
TGT_RR=2.0

# ── Reference only (shown in dashboard) ──────────────────────────
# Soft target = entry + TGT_RR × risk_pts  (display only, not an exit)
# Phase 3 greedy trail activates near this level
