//@version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║   🇮🇳 INDIA OPTIONS AUTO-TRADER — Kotak Neo Edition          ║
// ║   Pine Script v6 | NSE F&O | NIFTY / BANKNIFTY / FINNIFTY   ║
// ║   Broker: Kotak Neo API v2 (neo_api_client SDK)              ║
// ║   Webhook → broker_bridge_kotak.py → Live NFO Orders         ║
// ╚══════════════════════════════════════════════════════════════╝
indicator("🇮🇳 Kotak Neo Options Trader", overlay=true, max_labels_count=500, max_lines_count=500)

// ═════════════════════════════════════════════════════════════════
// SECTION 1 — INPUTS
// ═════════════════════════════════════════════════════════════════

// ── Index & Instrument ─────────────────────────────────────────
var string GRP_IDX = "═══ Index & Instrument ═══"
index_name  = input.string("BANKNIFTY", "Index",    options=["NIFTY", "BANKNIFTY", "FINNIFTY", "MIDCPNIFTY"], group=GRP_IDX)
lot_size    = input.int(15,  "Lot Size",  tooltip="NIFTY=50 | BANKNIFTY=15 | FINNIFTY=40 | MIDCPNIFTY=75", group=GRP_IDX)
num_lots    = input.int(1,   "Max Lots",  minval=1, maxval=50, group=GRP_IDX)
option_type = input.string("AUTO", "Option Type",   options=["AUTO", "CE Only", "PE Only"], group=GRP_IDX)
strike_mode = input.string("ATM",  "Strike",        options=["ATM", "OTM1", "OTM2", "ITM1"], group=GRP_IDX,
              tooltip="ATM=At the money | OTM1=1 strike out | OTM2=2 strikes out | ITM1=1 strike in")
expiry_type = input.string("Weekly", "Expiry",      options=["Weekly", "Monthly"], group=GRP_IDX,
              tooltip="BANKNIFTY expires Wednesday | NIFTY/FINNIFTY expires Thursday")

// ── Capital & Risk ─────────────────────────────────────────────
var string GRP_RISK = "═══ Capital & Risk Management ═══"
capital        = input.float(100000, "Capital (₹)",       minval=10000, group=GRP_RISK)
risk_per_trade = input.float(2.0,    "Risk % per Trade",  minval=0.5, maxval=10, group=GRP_RISK)
max_daily_loss = input.float(5.0,    "Max Daily Loss %",  minval=1, maxval=20, group=GRP_RISK)
max_trades_day = input.int(3,        "Max Trades / Day",  minval=1, maxval=10, group=GRP_RISK)

// ── Indicator Settings ─────────────────────────────────────────
var string GRP_IND = "═══ Indicator Settings ═══"
fast_len    = input.int(9,    "Fast EMA",              group=GRP_IND)
mid_len     = input.int(21,   "Mid EMA",               group=GRP_IND)
slow_len    = input.int(50,   "Slow EMA",              group=GRP_IND)
trend_len   = input.int(200,  "Trend EMA",             group=GRP_IND)
st_atr_len  = input.int(10,   "Supertrend ATR Len",    group=GRP_IND)
st_factor   = input.float(3.0,"Supertrend Factor",     group=GRP_IND)
rsi_len     = input.int(14,   "RSI Length",            group=GRP_IND)
rsi_ob      = input.int(70,   "RSI Overbought",        group=GRP_IND)
rsi_os      = input.int(30,   "RSI Oversold",          group=GRP_IND)
use_vwap    = input.bool(true, "Use VWAP Filter",      group=GRP_IND)
vol_mult    = input.float(1.5, "Volume Spike Mult",    group=GRP_IND)
adx_len     = input.int(14,   "ADX Length",            group=GRP_IND)
adx_thresh  = input.int(25,   "ADX Threshold",         group=GRP_IND)

// ── SL / Target / Trailing ─────────────────────────────────────
var string GRP_SL = "═══ SL / Target / Trail ═══"
sl_mode      = input.string("ATR",    "SL Mode",     options=["ATR", "Fixed %", "Swing"], group=GRP_SL)
sl_atr_mult  = input.float(1.5,       "SL ATR Mult", group=GRP_SL)
sl_pct       = input.float(0.8,       "SL Fixed %",  group=GRP_SL)
tgt_mode     = input.string("2:1 RR", "Target Mode", options=["2:1 RR", "3:1 RR", "Fixed %", "ATR"], group=GRP_SL)
tgt_pct      = input.float(1.5,       "Target Fixed %", group=GRP_SL)
tgt_atr_mult = input.float(3.0,       "Target ATR Mult", group=GRP_SL)
use_trail    = input.bool(true,        "Enable Trail SL",  group=GRP_SL)
trail_mode   = input.string("ATR",    "Trail Mode",  options=["ATR", "Fixed %", "Breakeven+"], group=GRP_SL)
trail_trigger= input.float(0.5,       "Trail Trigger (ATR/% mult)", group=GRP_SL)
trail_step   = input.float(0.3,       "Trail Step (ATR/% mult)",   group=GRP_SL)

// ── Session Filter ─────────────────────────────────────────────
var string GRP_SES = "═══ Session Filter ═══"
session_filter = input.bool(true,  "IST Session Only (9:15–15:30)", group=GRP_SES)
morning_avoid  = input.bool(true,  "Avoid 9:15–9:30 Open Noise",    group=GRP_SES)
eod_avoid      = input.bool(true,  "Avoid 15:10–15:30 EOD Risk",    group=GRP_SES)
avoid_monday   = input.bool(false, "Avoid Monday Open Gap",         group=GRP_SES)
avoid_expiry   = input.bool(true,  "Avoid Expiry Day Morning",      group=GRP_SES,
                 tooltip="Skip 9:15–10:00 on expiry day (high IV crush risk)")

// ── Kotak Neo Webhook ──────────────────────────────────────────
var string GRP_WH = "═══ Kotak Neo Webhook ═══"
webhook_enabled  = input.bool(false,            "Enable Webhook to Kotak Neo",  group=GRP_WH)
kotak_api_tag    = input.string("MY_API_KEY_TAG","Webhook Secret Tag",           group=GRP_WH,
                   tooltip="Must match WEBHOOK_SECRET in your .env file")
kotak_env        = input.string("prod",          "Environment",                  options=["prod","uat"], group=GRP_WH,
                   tooltip="prod = live trading | uat = paper/sandbox")
server_url       = input.string("https://your-server.com", "Bridge Server URL", group=GRP_WH,
                   tooltip="Your broker_bridge_kotak.py server URL (e.g. ngrok or VPS)")
squareoff_eod    = input.bool(true,             "Auto Square-Off at 15:10",     group=GRP_WH,
                   tooltip="Sends squareoff_all webhook at 15:10 IST")

// ═════════════════════════════════════════════════════════════════
// SECTION 2 — SESSION & EXPIRY UTILITIES
// ═════════════════════════════════════════════════════════════════
ist_session  = "0915-1530:1234567"
is_market    = not session_filter or (time(timeframe.period, ist_session, "Asia/Kolkata") != 0)

// Time helpers (IST)
_hour   = hour(time,   "Asia/Kolkata")
_minute = minute(time, "Asia/Kolkata")
_dow    = dayofweek(time, "Asia/Kolkata")

is_open_noise  = morning_avoid and (_hour == 9  and _minute < 30)
is_eod_window  = eod_avoid     and (_hour == 15 and _minute >= 10)
is_monday_open = avoid_monday  and (_dow == dayofweek.monday and _hour == 9 and _minute < 45)

// Expiry day detection:
//   BANKNIFTY = Wednesday (dayofweek.wednesday = 4 in Pine)
//   NIFTY / FINNIFTY / MIDCPNIFTY = Thursday (dayofweek.thursday = 5)
is_banknifty    = index_name == "BANKNIFTY"
expiry_weekday  = is_banknifty ? dayofweek.wednesday : dayofweek.thursday
is_expiry_day   = _dow == expiry_weekday
is_expiry_noise = avoid_expiry and is_expiry_day and (_hour == 9 and _minute < 60 or _hour == 10 and _minute < 0)

// Kotak-specific: avoid last 5 min on expiry day (extreme gamma/IV)
is_expiry_eod   = is_expiry_day and _hour == 15 and _minute >= 0

// Combined session gate
trade_allowed = is_market and not is_open_noise and not is_eod_window and not is_monday_open and not is_expiry_noise

// Square-off trigger for Kotak: 15:10 IST
sq_off_trigger = squareoff_eod and _hour == 15 and _minute == 10

// ═════════════════════════════════════════════════════════════════
// SECTION 3 — INDICATORS
// ═════════════════════════════════════════════════════════════════

// EMAs
ema_fast  = ta.ema(close, fast_len)
ema_mid   = ta.ema(close, mid_len)
ema_slow  = ta.ema(close, slow_len)
ema_trend = ta.ema(close, trend_len)

// ATR
atr = ta.atr(14)

// Supertrend
[st_line, st_dir] = ta.supertrend(st_factor, st_atr_len)
st_bull = st_dir == -1
st_bear = st_dir ==  1

// RSI
rsi = ta.rsi(close, rsi_len)

// VWAP (reset at session open — Pine v6 built-in)
vwap_val = ta.vwap(hlc3)

// Volume
vol_avg   = ta.sma(volume, 20)
vol_spike = volume > vol_avg * vol_mult

// ADX / DMI
[di_plus, di_minus, adx_val] = ta.dmi(adx_len, adx_len)
is_trending = adx_val > adx_thresh

// Bollinger Band squeeze (avoid low-volatility breakouts)
[bb_mid, bb_up, bb_lo] = ta.bb(close, 20, 2.0)
bb_width   = (bb_up - bb_lo) / bb_mid
bb_squeeze = bb_width < ta.sma(bb_width, 20) * 0.8

// ═════════════════════════════════════════════════════════════════
// SECTION 4 — SIGNAL LOGIC
// ═════════════════════════════════════════════════════════════════

bull_trend = close > ema_trend and ema_fast > ema_slow
bear_trend = close < ema_trend and ema_fast < ema_slow

vwap_bull = not use_vwap or close > vwap_val
vwap_bear = not use_vwap or close < vwap_val

ema_cross_up   = ta.crossover(ema_fast,  ema_mid)
ema_cross_down = ta.crossunder(ema_fast, ema_mid)

rsi_buy_ok  = rsi > 50 and rsi < rsi_ob
rsi_sell_ok = rsi < 50 and rsi > rsi_os

// 7-confirmation CE signal
raw_buy = ema_cross_up and bull_trend and st_bull and vwap_bull and rsi_buy_ok and is_trending and vol_spike and trade_allowed and not bb_squeeze

// 7-confirmation PE signal
raw_sell = ema_cross_down and bear_trend and st_bear and vwap_bear and rsi_sell_ok and is_trending and vol_spike and trade_allowed and not bb_squeeze

buy_signal  = raw_buy  and option_type != "PE Only"
sell_signal = raw_sell and option_type != "CE Only"

// ═════════════════════════════════════════════════════════════════
// SECTION 5 — SL / TARGET / POSITION SIZING
// ═════════════════════════════════════════════════════════════════
swing_lo = ta.lowest(low,  10)
swing_hi = ta.highest(high, 10)

// Stop Loss
float sl_buy = 0.0
if sl_mode == "ATR"
    sl_buy := close - atr * sl_atr_mult
else if sl_mode == "Fixed %"
    sl_buy := close * (1 - sl_pct / 100)
else
    sl_buy := swing_lo

float sl_sell = 0.0
if sl_mode == "ATR"
    sl_sell := close + atr * sl_atr_mult
else if sl_mode == "Fixed %"
    sl_sell := close * (1 + sl_pct / 100)
else
    sl_sell := swing_hi

// Risk in underlying points
risk_pts_buy  = math.max(close - sl_buy,  1.0)
risk_pts_sell = math.max(sl_sell - close, 1.0)

// Target
rr = tgt_mode == "2:1 RR" ? 2.0 : tgt_mode == "3:1 RR" ? 3.0 : 0.0

float tgt_buy = 0.0
if tgt_mode == "Fixed %"
    tgt_buy := close * (1 + tgt_pct / 100)
else if tgt_mode == "ATR"
    tgt_buy := close + atr * tgt_atr_mult
else
    tgt_buy := close + risk_pts_buy * rr

float tgt_sell = 0.0
if tgt_mode == "Fixed %"
    tgt_sell := close * (1 - tgt_pct / 100)
else if tgt_mode == "ATR"
    tgt_sell := close - atr * tgt_atr_mult
else
    tgt_sell := close - risk_pts_sell * rr

// Auto lot sizing: risk ₹ / (ATR risk pts × lot size)
risk_amt = capital * (risk_per_trade / 100)
qty_lots = math.min(num_lots, math.max(1, math.floor(risk_amt / (risk_pts_buy * lot_size))))

// ═════════════════════════════════════════════════════════════════
// SECTION 6 — TRAILING STOP (chart-side tracking)
// ═════════════════════════════════════════════════════════════════
var float trail_sl_buy  = na
var float trail_sl_sell = na
var bool  in_long       = false
var bool  in_short      = false
var float entry_price   = na

if buy_signal
    in_long       := true
    in_short      := false
    entry_price   := close
    trail_sl_buy  := sl_buy

if sell_signal
    in_short      := true
    in_long       := false
    entry_price   := close
    trail_sl_sell := sl_sell

// Trail for longs
if in_long and use_trail
    trig_l = trail_mode == "ATR" ? entry_price + atr * trail_trigger : entry_price * (1 + trail_trigger / 100)
    if close >= trig_l
        var float new_trail_l = 0.0
        if trail_mode == "ATR"
            new_trail_l := close - atr * trail_step
        else if trail_mode == "Fixed %"
            new_trail_l := close * (1 - trail_step / 100)
        else
            new_trail_l := entry_price
        trail_sl_buy := math.max(trail_sl_buy, new_trail_l)
    if close <= trail_sl_buy
        in_long := false

// Trail for shorts
if in_short and use_trail
    trig_s = trail_mode == "ATR" ? entry_price - atr * trail_trigger : entry_price * (1 - trail_trigger / 100)
    if close <= trig_s
        var float new_trail_s = 0.0
        if trail_mode == "ATR"
            new_trail_s := close + atr * trail_step
        else if trail_mode == "Fixed %"
            new_trail_s := close * (1 + trail_step / 100)
        else
            new_trail_s := entry_price
        trail_sl_sell := math.min(trail_sl_sell, new_trail_s)
    if close >= trail_sl_sell
        in_short := false

// ═════════════════════════════════════════════════════════════════
// SECTION 7 — DAILY TRADE COUNTER
// ═════════════════════════════════════════════════════════════════
var int   daily_trades = 0
var float daily_pnl    = 0.0
var int   last_day     = na

is_new_day = dayofmonth != last_day
if is_new_day
    daily_trades := 0
    daily_pnl    := 0.0
    last_day     := dayofmonth

daily_limit_hit = daily_trades >= max_trades_day or daily_pnl <= -(capital * max_daily_loss / 100)

// ═════════════════════════════════════════════════════════════════
// SECTION 8 — KOTAK NEO WEBHOOK JSON BUILDER
// ═════════════════════════════════════════════════════════════════
//
// Payload matches exactly what broker_bridge_kotak.py expects:
//   exchange_segment : "nfo_fo"
//   product          : "INTRADAY"
//   environment      : "prod" or "uat"
//   expiry_weekday   : "WED" (BANKNIFTY) or "THU" (others)
//   strike_mode      : "ATM" | "OTM1" | "OTM2" | "ITM1"
//   sl / target      : underlying price levels (bridge converts to option premium)
// ─────────────────────────────────────────────────────────────────

// Kotak Neo segment constants
_segment  = "nfo_fo"
_product  = "INTRADAY"

// Expiry weekday string (used by Python bridge for symbol construction)
_exp_day  = is_banknifty ? "WED" : "THU"

// JSON field helpers — pre-compute to keep webhook strings on single lines
_j_entry = str.tostring(math.round(close,    2))
_j_sl_b  = str.tostring(math.round(sl_buy,  2))
_j_sl_s  = str.tostring(math.round(sl_sell, 2))
_j_tgt_b = str.tostring(math.round(tgt_buy, 2))
_j_tgt_s = str.tostring(math.round(tgt_sell,2))
_j_atr   = str.tostring(math.round(atr,     2))
_j_adx   = str.tostring(math.round(adx_val, 1))
_j_rsi   = str.tostring(math.round(rsi,     1))
_j_vwap  = str.tostring(math.round(vwap_val,2))
_j_lots  = str.tostring(qty_lots)
_j_ls    = str.tostring(lot_size)
_j_trail = use_trail ? trail_mode : "OFF"

// CE webhook — entire string on ONE line (Pine v6 requires this)
kotak_buy = '{"tag":"' + kotak_api_tag + '","broker":"KotakNeo","environment":"' + kotak_env + '","action":"BUY_CE","exchange_segment":"' + _segment + '","product":"' + _product + '","index":"' + index_name + '","strike":"' + strike_mode + '","expiry":"' + expiry_type + '","expiry_weekday":"' + _exp_day + '","lots":' + _j_lots + ',"lot_size":' + _j_ls + ',"entry":' + _j_entry + ',"sl":' + _j_sl_b + ',"target":' + _j_tgt_b + ',"atr":' + _j_atr + ',"trail":"' + _j_trail + '","adx":' + _j_adx + ',"rsi":' + _j_rsi + ',"vwap":' + _j_vwap + ',"tf":"' + timeframe.period + '"}' 

// PE webhook — entire string on ONE line
kotak_sell = '{"tag":"' + kotak_api_tag + '","broker":"KotakNeo","environment":"' + kotak_env + '","action":"BUY_PE","exchange_segment":"' + _segment + '","product":"' + _product + '","index":"' + index_name + '","strike":"' + strike_mode + '","expiry":"' + expiry_type + '","expiry_weekday":"' + _exp_day + '","lots":' + _j_lots + ',"lot_size":' + _j_ls + ',"entry":' + _j_entry + ',"sl":' + _j_sl_s + ',"target":' + _j_tgt_s + ',"atr":' + _j_atr + ',"trail":"' + _j_trail + '","adx":' + _j_adx + ',"rsi":' + _j_rsi + ',"vwap":' + _j_vwap + ',"tf":"' + timeframe.period + '"}' 

// Square-off ALL — one line
kotak_squareoff = '{"tag":"' + kotak_api_tag + '","action":"SQUAREOFF_ALL","broker":"KotakNeo","environment":"' + kotak_env + '"}'

// ═════════════════════════════════════════════════════════════════
// SECTION 9 — PLOTS & VISUALS
// ═════════════════════════════════════════════════════════════════

// EMAs
plot(ema_fast,  "EMA 9",   color=color.new(color.aqua,    0), linewidth=1)
plot(ema_mid,   "EMA 21",  color=color.new(color.yellow,  0), linewidth=1)
plot(ema_slow,  "EMA 50",  color=color.new(color.orange,  0), linewidth=2)
plot(ema_trend, "EMA 200", color=color.new(color.white,  30), linewidth=2)

// VWAP
plot(use_vwap ? vwap_val : na, "VWAP", color=color.new(color.fuchsia, 0), linewidth=2, style=plot.style_circles)

// Supertrend
plot(st_bull ? st_line : na, "ST Bull", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(st_bear ? st_line : na, "ST Bear", color=color.new(color.red,  0), linewidth=2, style=plot.style_linebr)

// Trailing SL lines
plot(in_long  ? trail_sl_buy  : na, "Trail SL Long",  color=color.new(color.red,   0), linewidth=1, style=plot.style_linebr)
plot(in_short ? trail_sl_sell : na, "Trail SL Short", color=color.new(color.green, 0), linewidth=1, style=plot.style_linebr)

// Target lines (show only on signal bar)
plot(buy_signal  ? tgt_buy  : na, "Target Long",  color=color.new(color.lime,   60), linewidth=1, style=plot.style_linebr)
plot(sell_signal ? tgt_sell : na, "Target Short", color=color.new(color.orange, 60), linewidth=1, style=plot.style_linebr)

// Expiry day highlight band
bgcolor(is_expiry_day ? color.new(color.purple, 90) : na, title="Expiry Day Highlight")

// BB squeeze indicator (bottom dots)
plotshape(bb_squeeze, "BB Squeeze", location=location.bottom, color=color.new(color.purple, 30), style=shape.circle, size=size.tiny)

// ── Buy / Sell arrows ──────────────────────────────────────────
buy_final  = buy_signal  and not daily_limit_hit
sell_final = sell_signal and not daily_limit_hit

plotshape(buy_final,  "BUY CE",  location=location.belowbar, color=color.new(color.lime, 0), style=shape.labelup,   size=size.normal, text="CE📈")
plotshape(sell_final, "BUY PE",  location=location.abovebar, color=color.new(color.red,  0), style=shape.labeldown, size=size.normal, text="PE📉")

// Trailing SL exit markers
trail_exit_long  = in_long[1]  and not in_long
trail_exit_short = in_short[1] and not in_short
plotshape(trail_exit_long,  "TSL Exit Long",  location=location.abovebar, color=color.new(color.yellow, 0), style=shape.xcross, size=size.small, text="TSL✂")
plotshape(trail_exit_short, "TSL Exit Short", location=location.belowbar, color=color.new(color.yellow, 0), style=shape.xcross, size=size.small, text="TSL✂")

// Expiry day morning caution label
if is_expiry_day and _hour == 9 and _minute == 15 and barstate.isrealtime
    label.new(bar_index, high, "⚠ EXPIRY DAY\nHigh IV Risk", color=color.new(color.purple, 20), textcolor=color.white, style=label.style_label_down, size=size.small)

// ═════════════════════════════════════════════════════════════════
// SECTION 10 — INFO TABLE (Top Right — Kotak Neo Edition)
// ═════════════════════════════════════════════════════════════════
var table info_tbl = table.new(position.top_right, 2, 15, border_width=1)

// Kotak Neo status color (orange = Kotak brand color)
kotak_color = color.new(color.orange, 0)

if barstate.islast
    // ── Header ──
    table.cell(info_tbl, 0, 0, "KOTAK NEO OPTIONS",
         text_color=color.white, bgcolor=color.new(color.orange, 10), text_size=size.small)
    table.cell(info_tbl, 1, 0, index_name + " | " + expiry_type + " | " + kotak_env,
         text_color=color.yellow, bgcolor=color.new(color.orange, 10), text_size=size.small)

    // ── Session ──
    table.cell(info_tbl, 0, 1, "Session",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 1, trade_allowed ? "✅ TRADING" : "🚫 BLOCKED",
         text_color=trade_allowed ? color.lime : color.red, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Expiry ──
    table.cell(info_tbl, 0, 2, "Expiry Day",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 2, is_expiry_day ? "⚠ TODAY (" + (is_banknifty ? "WED" : "THU") + ")" : (is_banknifty ? "WED" : "THU"),
         text_color=is_expiry_day ? color.orange : color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Trend ──
    table.cell(info_tbl, 0, 3, "Trend",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 3, bull_trend ? "BULLISH" : bear_trend ? "BEARISH" : "SIDEWAYS",
         text_color=bull_trend ? color.lime : bear_trend ? color.red : color.yellow, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── ADX ──
    table.cell(info_tbl, 0, 4, "ADX",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 4, str.tostring(math.round(adx_val, 1)) + (is_trending ? " ✅" : " ⚠"),
         text_color=is_trending ? color.lime : color.orange, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── RSI ──
    table.cell(info_tbl, 0, 5, "RSI",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 5, str.tostring(math.round(rsi, 1)),
         text_color=rsi > rsi_ob ? color.red : rsi < rsi_os ? color.lime : color.white, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── ATR ──
    table.cell(info_tbl, 0, 6, "ATR",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 6, str.tostring(math.round(atr, 1)),
         text_color=color.white, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── VWAP ──
    table.cell(info_tbl, 0, 7, "VWAP",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 7, str.tostring(math.round(vwap_val, 1)) + (close > vwap_val ? " ▲" : " ▼"),
         text_color=close > vwap_val ? color.lime : color.red, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Strike mode ──
    table.cell(info_tbl, 0, 8, "Strike",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 8, strike_mode + " | " + (is_banknifty ? "100pt step" : "50pt step"),
         text_color=color.white, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── SL / Target ──
    table.cell(info_tbl, 0, 9, "SL / Target",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    _sl_val  = in_long ? str.tostring(math.round(trail_sl_buy, 0)) : in_short ? str.tostring(math.round(trail_sl_sell, 0)) : "-"
    _tgt_val = in_long ? str.tostring(math.round(tgt_buy, 0))      : in_short ? str.tostring(math.round(tgt_sell, 0))      : "-"
    table.cell(info_tbl, 1, 9, _sl_val + " / " + _tgt_val,
         text_color=color.orange, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Lots / Qty ──
    table.cell(info_tbl, 0, 10, "Lots / Qty",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 10, str.tostring(qty_lots) + " lots = " + str.tostring(qty_lots * lot_size) + " qty",
         text_color=color.white, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Risk ₹ ──
    table.cell(info_tbl, 0, 11, "Risk ₹",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 11, "Rs." + str.tostring(math.round(risk_amt, 0)),
         text_color=color.orange, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Daily trades ──
    table.cell(info_tbl, 0, 12, "Trades",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 12, str.tostring(daily_trades) + "/" + str.tostring(max_trades_day) + (daily_limit_hit ? " HALTED" : " OK"),
         text_color=daily_limit_hit ? color.red : color.lime, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Webhook ──
    table.cell(info_tbl, 0, 13, "Webhook",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 13, webhook_enabled ? "LIVE " + kotak_env : "OFF",
         text_color=webhook_enabled ? color.lime : color.red, bgcolor=color.new(color.black, 20), text_size=size.tiny)

    // ── Segment ──
    table.cell(info_tbl, 0, 14, "Segment",
         text_color=color.gray, bgcolor=color.new(color.black, 20), text_size=size.tiny)
    table.cell(info_tbl, 1, 14, "nfo_fo | INTRADAY | MIS",
         text_color=kotak_color, bgcolor=color.new(color.black, 20), text_size=size.tiny)

// ═════════════════════════════════════════════════════════════════
// SECTION 11 — ALERTS (alertcondition + live webhook)
// ═════════════════════════════════════════════════════════════════

// Standard TradingView alert conditions (works without webhook)
alertcondition(buy_final,        "CE Buy  — Kotak Neo",          "CE BUY  | {{ticker}} | {{close}}")
alertcondition(sell_final,       "PE Buy  — Kotak Neo",          "PE BUY  | {{ticker}} | {{close}}")
alertcondition(trail_exit_long,  "Trail Exit Long  — Kotak Neo", "TRAIL EXIT LONG  | {{ticker}} | {{close}}")
alertcondition(trail_exit_short, "Trail Exit Short — Kotak Neo", "TRAIL EXIT SHORT | {{ticker}} | {{close}}")
alertcondition(daily_limit_hit,  "Daily Limit Hit — Kotak Neo",  "DAILY LIMIT HIT — halting signals")
alertcondition(sq_off_trigger,   "Square Off All  — Kotak Neo",  "SQUARE OFF ALL — EOD 15:10")
alertcondition(is_expiry_day,    "Expiry Day Warning",           "EXPIRY DAY — elevated IV / gamma risk")

// ── Kotak Neo live webhook alerts ─────────────────────────────
// These fire as bar-close JSON payloads to your broker_bridge_kotak.py server.
// Set alert → Webhook URL → https://your-server.com/webhook
if webhook_enabled
    if buy_final
        alert(kotak_buy,  alert.freq_once_per_bar_close)
    if sell_final
        alert(kotak_sell, alert.freq_once_per_bar_close)
    if sq_off_trigger
        alert(kotak_squareoff, alert.freq_once_per_bar_close)
