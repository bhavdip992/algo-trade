# ════════════════════════════════════════════════════════════════════════
#  .env — Kotak Neo Auto-Trader
#  Copy this file as  .env  in your project folder.
#  NEVER commit to git. Add .env to your .gitignore.
# ════════════════════════════════════════════════════════════════════════

# ── Kotak Neo Credentials ────────────────────────────────────────────────
KOTAK_CONSUMER_KEY=1a1ec856-1528-46ef-95fa-6e2a70c489a6
KOTAK_MOBILE=+917048525286
KOTAK_UCC=XHHPN
KOTAK_MPIN=525286
KOTAK_TOTP_SECRET=NGSOHK4XSZXAKXS4EC42RWUZXA
ENVIRONMENT=prod

# ════════════════════════════════════════════════════════════════════════
#  TRADE MODE
#  true  = Paper trade (simulate, no real orders)
#  false = LIVE trade  (real money at Kotak Neo)
# ════════════════════════════════════════════════════════════════════════
PAPER_TRADE=false

# ════════════════════════════════════════════════════════════════════════
#  INDEX  — change this to trade a different index
#  Then also update LOT_SIZE, STRIKE_STEP, EXPIRY_WEEKDAY below.
#
#   NIFTY      → LOT_SIZE=75  STRIKE_STEP=50   EXPIRY_WEEKDAY=THU
#   BANKNIFTY  → LOT_SIZE=30  STRIKE_STEP=100  EXPIRY_WEEKDAY=WED
#   FINNIFTY   → LOT_SIZE=65  STRIKE_STEP=50   EXPIRY_WEEKDAY=THU
#   MIDCPNIFTY → LOT_SIZE=120 STRIKE_STEP=25   EXPIRY_WEEKDAY=THU
# ════════════════════════════════════════════════════════════════════════
INDEX=NIFTY
LOT_SIZE=65
STRIKE_STEP=50
EXPIRY_WEEKDAY=TUE

# ── Option settings ──────────────────────────────────────────────────────
EXPIRY_TYPE=Weekly          # Weekly | Monthly
STRIKE_MODE=OTM2            # ATM | OTM1 | OTM2 | ITM1
OPTION_TYPE=AUTO            # AUTO | CE Only | PE Only

# ── Candle timeframe ─────────────────────────────────────────────────────
TIMEFRAME=5                 # 1 | 3 | 5 | 10 | 15 (minutes)

# ════════════════════════════════════════════════════════════════════════
#  CAPITAL & RISK
# ════════════════════════════════════════════════════════════════════════
MAX_CAPITAL=100000           # Total capital to deploy (Rs.)
MAX_DAILY_LOSS=3            # Halt when daily loss > X% of capital (3% = Rs.600)
MAX_TRADES=3                # Max trades per day
MAX_PREMIUM=450             # Max option premium per share (Rs.) — protects capital
RISK_PCT=2.0                # Risk per trade as % of capital (2% of 100000 = Rs.2000)
MAX_LOTS=1                  # Max lots per trade

# ════════════════════════════════════════════════════════════════════════
#  SIGNAL ENGINE PARAMETERS
# ════════════════════════════════════════════════════════════════════════

# EMA lengths
EMA_FAST=9
EMA_MID=21
EMA_SLOW=50
EMA_TREND=200               # Engine needs this many candles to warm up

# Supertrend
ST_ATR_LEN=10
ST_FACTOR=2.5

# RSI
RSI_LEN=14
RSI_OB=65                   # Block CE buy when RSI > this
RSI_OS=32                   # Block PE buy when RSI < this

# ADX (trend strength)
ADX_THRESH=22               # Min ADX to trade: 15=loose 20=moderate 25=strict

# Volume
VOL_MULT=1.2                # Volume must be X times 20-bar average
VOL_REQUIRED=false        # false = volume is optional (safe for index spot feed)

# Bollinger Bands
BB_LEN=20
BB_STD=2.0

# Minimum confirmations to fire a signal (out of 8)
# 4=loose  5=balanced  6=strict
MIN_CONFIRMATIONS=5

# Stop Loss
SL_MODE=ATR                 # ATR | Fixed% | Swing
SL_ATR_MULT=1.2
SL_PCT=0.8

# Target
TGT_MODE=ATR             # 2:1 RR | 3:1 RR | Fixed% | ATR
TGT_PCT=1.5
TGT_ATR_MULT=2.5

# Trailing Stop Loss
USE_TRAIL=true
TRAIL_TRIG=0.8
TRAIL_STEP=0.4
